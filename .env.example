# Appwrite
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your_database_id
NEXT_PUBLIC_APPWRITE_BUCKET_ID=your_bucket_id

# Admin (DO NOT use NEXT_PUBLIC_ prefix - server-side only)
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Email Service (server-side only, no NEXT_PUBLIC_ prefix)
# For production: set EMAIL_WEBHOOK_URL to your email service endpoint
# (e.g., SendGrid webhook, Resend API, or a custom SMTP relay)
EMAIL_WEBHOOK_URL=

# Legacy EmailJS config (kept for reference)
# EMAILJS_SERVICE_ID=your_service_id
# EMAILJS_TEMPLATE_ID=your_template_id
# EMAILJS_PUBLIC_KEY=your_user_id
